# SIR model
```{r}
sir_model <- function(time, state, parameters) {
  
  with(as.list(c(state, parameters)), {
    
    dS <- -beta * S * I / N
    dI <- beta * S * I / N - gamma * I
    dR <- gamma * I
    
    list(c(dS, dI, dR))})}

### parameters

gamma <- 1/7

R0_values <- c(12, 18)

vax_rates <- c(0.95, 0.90, 0.85, 0.80)

N <- 1000000

I0 <- 10

VE <- 0.97

R0_init <- 0

time <- seq(0, 365, by = 1)

results_list <- list()

### Run scenarios

for (r0 in R0_values) {
  beta <- r0 * gamma
  for (v in vax_rates) {
    S0 <- N * (1 - v * VE) - I0
    init <- c(
      S = S0,
      I = I0,
      R = R0_init)
    
    parameters <- c(
      beta = beta,
      gamma = gamma,
      N = N)
    
    out <- ode(
      y = init,
      times = time,
      func = sir_model,
      parms = parameters)
    
    df <- as.data.frame(out) %>%
      mutate(
        vaccination = v,
        baseline_R0 = r0)
    results_list[[paste(r0, v)]] <- df}}

sir_results <- bind_rows(results_list)
```

```{r}
df <- as.data.frame(out) %>%
  mutate(
    vaccination = v,
    vaccination_label = paste0(v * 100, "%"),
    baseline_R0 = r0)
