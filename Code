  filter(vaccination == 0.95)

comparison_table <- summary_table %>%
  
  left_join(
    gold_standard,
    by = "baseline_R0",
    suffix = c("", "_gold")) %>%
  
  mutate(
    excess_peak =
      peak_infections - peak_infections_gold,
    excess_total =
      total_infected - total_infected_gold,
    percent_increase_total =
      100 *
